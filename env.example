# ══════════════════════════════════════════════════════
#  Simulador IoT — Configuración de entorno
#  Copiá este archivo como .env y completá los valores
#  cp .env.example .env
# ══════════════════════════════════════════════════════

# ── Broker MQTT ───────────────────────────────────────
# Broker público gratuito (sin login, sin TLS):
MQTT_HOST=broker.hivemq.com
MQTT_PORT=1883

# Broker propio en la nube con autenticación:
# MQTT_HOST=tu-broker.ejemplo.com
# MQTT_PORT=8883
# MQTT_USER=tu_usuario
# MQTT_PASSWORD=tu_contraseña_segura

# ── TLS / SSL ─────────────────────────────────────────
# Activar TLS para producción (True/False)
MQTT_TLS=False

# Rutas a certificados (solo si MQTT_TLS=True)
# MQTT_CA_CERT=./certs/ca.crt
# MQTT_CLIENT_CERT=./certs/client.crt
# MQTT_CLIENT_KEY=./certs/client.key

# ── Simulación ────────────────────────────────────────
CANTIDAD_CASAS=10
INTERVALO_SEGUNDOS=5

# Tamaño máximo de la cola offline (mensajes guardados sin conexión)
COLA_MAX=500

# ── Umbrales de anomalías ─────────────────────────────
TENSION_MIN=195
TENSION_MAX=245
CONSUMO_MAX=4500
FACTOR_POTENCIA_MIN=0.75

# ── Logs ──────────────────────────────────────────────
# DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
